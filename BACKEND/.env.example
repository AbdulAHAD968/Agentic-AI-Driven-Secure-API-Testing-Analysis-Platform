# =============================================================================
# BACKEND — Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in real values before starting the server.
# NEVER commit the actual .env file to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# MongoDB connection string (Atlas or self-hosted).
# Format: mongodb+srv://<user>:<password>@<cluster>/<dbname>?appName=<app>
MONGODB_URL=mongodb+srv://<db_user>:<db_password>@cluster0.example.mongodb.net/?appName=MyApp


# -----------------------------------------------------------------------------
# AUTHENTICATION — JWT
# -----------------------------------------------------------------------------
# Secret used to sign JWT tokens. Must be at least 32 characters.
# Generate a strong value with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET_KEY=<your-64-character-random-hex-secret>


# -----------------------------------------------------------------------------
# VAULT ENCRYPTION
# -----------------------------------------------------------------------------
# Used to derive the AES-256 key for encrypting uploaded source code.
# VAULT_SECRET must be kept secret. VAULT_SALT can be any unique string per
# deployment (acts as a KDF salt — changing it invalidates existing vault files).
# Generate VAULT_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
VAULT_SECRET=<your-random-32-byte-base64-secret>
VAULT_SALT=<your-unique-deployment-salt>


# -----------------------------------------------------------------------------
# CORS — Allowed Origins
# -----------------------------------------------------------------------------
# URLs of the frontend and admin apps. Must match exactly (no trailing slash).
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001


# -----------------------------------------------------------------------------
# ADMIN ACCESS
# -----------------------------------------------------------------------------
# Password used for admin-specific internal operations.
ADMIN_PASS=<your-admin-panel-password>

# Comma-separated list of emails that are automatically promoted to role=admin
# when they first sign in through Ory. Add your admin email(s) here.
ADMIN_EMAILS=admin@yourdomain.com


# -----------------------------------------------------------------------------
# EMAIL (SMTP)
# -----------------------------------------------------------------------------
# Used for sending email verification, password reset, and newsletter emails.
# Example below uses Gmail with an App Password (not your account password).
ADMIN_EMAIL=admin@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-sending-email@gmail.com
SMTP_PASSWORD=<gmail-app-password>
FROM_EMAIL=your-sending-email@gmail.com
FROM_NAME=Your App Name


# -----------------------------------------------------------------------------
# CLOUDINARY — Avatar / File Storage
# -----------------------------------------------------------------------------
# Get these from your Cloudinary dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>


# -----------------------------------------------------------------------------
# AI / LLM API Keys
# -----------------------------------------------------------------------------
# Provide one of the following. Uncomment the one you are using.

# OpenAI (GPT models)
#OPENAI_API_KEY=sk-proj-...

# Google Gemini
#GEMINI_API_KEY=AIza...


# -----------------------------------------------------------------------------
# ORY NETWORK — Authentication Provider
# -----------------------------------------------------------------------------
# Your Ory project's SDK URL. Find it in the Ory Console under
# Settings → Endpoints → SDK URL.
# This is server-side only (no NEXT_PUBLIC_ prefix needed here).
ORY_SDK_URL=https://<your-project-slug>.projects.oryapis.com
ORY_PROJECT_ID=<your-ory-project-uuid>
